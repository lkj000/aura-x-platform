# ─────────────────────────────────────────────────────────────────────────────
# AURA-X Platform — Environment Variables
# Copy this file to .env and fill in your values before running locally.
# For Railway/Render/Fly.io, set these in the platform's environment config.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────────

# Node environment: development | production
NODE_ENV=development

# Server port (Railway sets this automatically in production)
PORT=3000

# Secret used to sign JWT session cookies. Generate with:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string

# ── Database ──────────────────────────────────────────────────────────────────

# MySQL connection string
# Local:        mysql://root:password@localhost:3306/aurax
# TiDB Cloud:   mysql://user:password@gateway.tidbcloud.com:4000/aurax?ssl={"rejectUnauthorized":true}
# PlanetScale:  mysql://user:password@aws.connect.psdb.cloud/aurax?ssl={"rejectUnauthorized":true}
DATABASE_URL=mysql://root:password@localhost:3306/aurax

# ── AWS S3 (audio file storage) ───────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=aura-x-audio
S3_REGION=us-east-1

# ── Modal.com (AI generation — MusicGen, Demucs) ─────────────────────────────
# Get from: https://modal.com/settings/tokens
MODAL_API_KEY=
MODAL_BASE_URL=https://your-workspace--aura-x.modal.run

# ── Temporal (durable workflow engine) ───────────────────────────────────────
# Dev: leave TEMPORAL_SERVER_URL blank (defaults to localhost:7233 via docker-compose)
# Production (Temporal Cloud — cloud.temporal.io):
#   1. Create a namespace at cloud.temporal.io
#   2. Create an API key at Settings → API Keys
#   3. Set TEMPORAL_SERVER_URL to <namespace>.tmprl.cloud:7233
#   4. Set TEMPORAL_NAMESPACE to your namespace name (e.g. aura-x.production)
#   5. Set TEMPORAL_API_KEY to the API key value
TEMPORAL_SERVER_URL=
TEMPORAL_NAMESPACE=default
TEMPORAL_API_KEY=

# ── Stripe (marketplace payments) ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Admin ─────────────────────────────────────────────────────────────────────
# Email of the first registered user to automatically receive admin role
OWNER_EMAIL=your@email.com

# ── Public URL (used for Modal webhook callbacks) ────────────────────────────
# Set to your deployed API root so Modal can POST analysis/stem results back.
# Railway: https://your-service.up.railway.app
# Local dev: leave blank (webhooks won't fire; Temporal poll loop covers it)
PUBLIC_URL=

# ── Frontend (Vite) ───────────────────────────────────────────────────────────
# Comma-separated list of additional allowed hosts for the Vite dev server
# Example: VITE_ALLOWED_HOST=your-tunnel.ngrok.io,preview.yourapp.com
VITE_ALLOWED_HOST=
